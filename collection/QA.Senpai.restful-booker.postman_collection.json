    {
      "name": "Auth",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "\r",
              "let json = pm.response.json();\r",
              "pm.collectionVariables.set(\"token\", json.token)\r",
              "\r",
              "\r",
              "pm.test(\"Status code 200\", function() {\r",
              "    pm.response.to.have.status(200);\r",
              "    pm.response.to.have.status(\"OK\");\r",
              "\r",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201])\r",
              "})\r",
              "\r",
              "//console.log(pm)\r",
              "console.log(pm.response)\r",
              "\r",
              "//2nd priority\r",
              "\r",
              "let response = pm.response.json();\r",
              "console.log(response)\r",
              "\r",
              "pm.test(\"Body is correct\", function () {\r",
              "    pm.expect(response).to.be.an(\"object\")\r",
              "    pm.expect(response.token).to.be.a(\"string\")\r",
              "});\r",
              "\r",
              "pm.test(\"Response has headers\", function(){\r",
              "    pm.response.to.have.header(\"Content-Type\");\r",
              "    pm.response.to.have.header(\"Content-Length\");\r",
              "\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json; charset=utf-8\")\r",
              "})\r",
              "\r",
              "\r",
              "pm.test(\"Response has less than 500ms duration\", function(){\r",
              "    pm.expect(pm.response.responseTime).to.be.below(500)\r",
              "})\r",
              "\r",
              "pm.test(\"Responce size less than 1kb\", function(){\r",
              "    pm.expect(pm.response.responseSize).to.be.below(1000)\r",
              "})\r",
              "\r",
              "\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
